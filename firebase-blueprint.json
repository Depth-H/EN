{
  "entities": {
    "Portfolio": {
      "title": "Portfolio",
      "description": "시공 사례 데이터 모델",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "프로젝트 제목" },
        "category": { "type": "string", "description": "카테고리 (호텔, 모텔, 상업시설, 조명특화)" },
        "image": { "type": "string", "format": "uri", "description": "이미지 URL" },
        "description": { "type": "string", "description": "상세 설명" },
        "createdAt": { "type": "string", "format": "date-time", "description": "등록일" },
        "authorUid": { "type": "string", "description": "작성자 UID" }
      },
      "required": ["title", "category", "image", "createdAt", "authorUid"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "고객 문의 데이터 모델",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "성함/업체명" },
        "phone": { "type": "string", "description": "연락처" },
        "email": { "type": "string", "format": "email", "description": "이메일" },
        "type": { "type": "string", "description": "문의 유형" },
        "message": { "type": "string", "description": "문의 내용" },
        "createdAt": { "type": "string", "format": "date-time", "description": "접수일" }
      },
      "required": ["name", "phone", "email", "type", "message", "createdAt"]
    },
    "News": {
      "title": "News",
      "description": "회사 소식/공지사항 데이터 모델",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "제목" },
        "content": { "type": "string", "description": "내용" },
        "image": { "type": "string", "format": "uri", "description": "대표 이미지 URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "작성일" },
        "authorUid": { "type": "string", "description": "작성자 UID" }
      },
      "required": ["title", "content", "createdAt", "authorUid"]
    },
    "Settings": {
      "title": "Settings",
      "description": "사이트 기본 설정 및 페이지 콘텐츠 데이터 모델",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "회사명" },
        "address": { "type": "string", "description": "주소" },
        "phone": { "type": "string", "description": "대표 전화" },
        "email": { "type": "string", "description": "대표 이메일" },
        "businessNumber": { "type": "string", "description": "사업자 등록번호" },
        "ceo": { "type": "string", "description": "대표자명" },
        "aboutHeadline": { "type": "string", "description": "회사소개 헤드라인" },
        "aboutVision": { "type": "string", "description": "비전 설명" },
        "aboutValues": { "type": "array", "description": "핵심 가치 리스트" },
        "aboutHistory": { "type": "array", "description": "회사 연혁 리스트" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "사업 분야/서비스 데이터 모델",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "서비스명" },
        "description": { "type": "string", "description": "상세 설명" },
        "iconName": { "type": "string", "description": "아이콘 이름 (Lucide)" },
        "features": { "type": "array", "description": "주요 특징 리스트" },
        "order": { "type": "number", "description": "표시 순서" }
      },
      "required": ["title", "description", "order"]
    }
  },
  "firestore": {
    "/portfolios/{portfolioId}": {
      "schema": "Portfolio",
      "description": "시공 사례 컬렉션"
    },
    "/inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "고객 문의 컬렉션"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "회사 소식 컬렉션"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "사이트 설정 컬렉션"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "사업 분야 컬렉션"
    }
  }
}
